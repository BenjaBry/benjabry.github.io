        }
        .header { border-bottom: 4px solid #1B2A4A; padding-bottom: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; }
        .brand h1 { color: #1B2A4A; margin: 0; font-size: 28px; }
        .brand p { color: #F47B20; margin: 5px 0; font-weight: bold; font-size: 12px; text-transform: uppercase; }
        table { width: 100%; border-collapse: collapse; }
        thead { background-color: #1B2A4A !important; color: white !important; }
        th { padding: 12px; font-size: 12px; }
        .total-box { margin-top: 30px; text-align: right; border-top: 2px solid #F47B20; padding-top: 15px; }
        .footer { margin-top: 80px; text-align: center; font-size: 10px; color: #777; border-top: 1px solid #eee; padding-top: 20px; }
      </style>
    </head>
    <body>
      <div class="page">
        <div class="header">
          <div class="brand"><h1>CYLO GUATEMALA</h1><p>Distribución Estratégica B2B</p></div>
          <div style="text-align: right;">
            <h2 style="margin:0; font-size: 18px;">COTIZACIÓN COMERCIAL</h2>
            <p><b>Folio:</b> ${quoteNumber}<br><b>Fecha:</b> ${today}</p>
          </div>
        </div>
        <table>
          <thead><tr><th>Cant.</th><th style="text-align:left;">Descripción</th><th style="text-align:right;">Precio U.</th><th style="text-align:right;">Subtotal</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
        <div class="total-box">
          <span style="font-size: 14px;">Total Estimado:</span>
          <span style="font-size: 22px; font-weight: bold; color: #1B2A4A; margin-left: 15px;">${totalFormateado}</span>
        </div>
        <div class="footer">
          <p>Documento generado para validación de inventario en Palín, Escuintla.</p>
          <p style="font-weight: bold;">cyloguatemala.me</p>
        </div>
      </div>
      <script>window.onload = function() { window.print(); };<\/script>
    </body>
    </html>
  `;

  const printWindow = window.open('', '_blank', 'width=850,height=1000');
  printWindow.document.write(printContent);
  printWindow.document.close();
}
</script>
