            let priceMatch = line.match(/Q\s*([\d,]+\.\d{2})/);
            if(priceMatch) priceVal = parseFloat(priceMatch[1].replace(/,/g, ''));
            else nameLines.push(line);
          });
          addToCart(nameLines.join(' | '), priceVal);
          btn.innerHTML = '✔ Agregado'; btn.style.background = '#25D366';
          setTimeout(() => { btn.innerHTML = '+ Agregar'; btn.style.background = '#1B2A4A'; }, 1500);
        };
        card.appendChild(btn);
      }
    });
  }, 1500);

  // === LÓGICA DEL CARRITO ===
  function addToCart(name, price) {
    let item = cart.find(i => i.name === name);
    if(item) item.qty++; else cart.push({ name: name, price: price, qty: 1 });
    saveCart();
  }

  function modifyQty(index, amount) {
    cart[index].qty += amount;
    if(cart[index].qty <= 0) cart.splice(index, 1);
    saveCart();
  }

  function saveCart() {
    try { localStorage.setItem('cylo_cart_v2', JSON.stringify(cart)); } catch(e) {}
    updateCartUI();
  }

  function updateCartUI() {
    let totalItems = 0; let grandTotal = 0;
    let container = document.getElementById('cart-items-container');
    container.innerHTML = '';
    
    if(cart.length === 0) {
      document.getElementById('cylo-cart-count').innerText = 0;
      document.getElementById('cylo-cart-btn').style.display = 'none';
      document.getElementById('cart-summary-container').style.display = 'none';
      container.innerHTML = '<p style="text-align:center; color:#888; margin-top:20px;">El carrito está vacío.</p>';
      return;
    }

    cart.forEach((item, index) => {
      totalItems += item.qty; let itemPrice = item.price || 0; let subtotal = item.qty * itemPrice;
      grandTotal += subtotal;
      container.innerHTML += `
        <div class="cart-item">
          <div class="item-info"><span class="item-name">${item.name}</span><span class="item-price">${formatMoney(itemPrice)} c/u</span></div>
          <div class="item-controls"><button class="qty-btn" onclick="modifyQty(${index}, -1)">-</button><span>${item.qty}</span><button class="qty-btn" onclick="modifyQty(${index}, 1)">+</button></div>
        </div>`;
    });

    document.getElementById('cylo-cart-count').innerText = totalItems;
    document.getElementById('cylo-cart-btn').style.display = 'flex';
    if(grandTotal > 0) {
      document.getElementById('cart-total-price').innerText = formatMoney(grandTotal);
      document.getElementById('cart-summary-container').style.display = 'block';
    } else { document.getElementById('cart-summary-container').style.display = 'none'; }
  }

  function toggleCart() {
    let modal = document.getElementById('cylo-cart-modal');
    modal.style.display = modal.style.display === 'flex' ? 'none' : 'flex';
  }

  // === MOTOR WHATSAPP ===
  function sendToWhatsApp() {
    if(cart.length === 0) return;
    let text = "Me interesa cotizar la siguiente orden:\n\n";
    let grandTotal = 0;
    cart.forEach(item => {
      let itemPrice = item.price || 0; let subtotal = item.qty * itemPrice; grandTotal += subtotal;
      text += `- *${item.qty}x* ${item.name}\n`;
      if(itemPrice > 0) text += `   ↳ Subtotal: ${formatMoney(subtotal)}\n\n`; else text += `\n`;
    });
    if(grandTotal > 0) {
      text += `══════════════════\n*TOTAL ESTIMADO: ${formatMoney(grandTotal)}*\n══════════════════\n\n`;
    }
    text += "Quedo a la espera de su confirmación para proceder.";
    let encodedText = encodeURIComponent(text);
    let isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    let url = isMobile ? `whatsapp://send?phone=${WHATSAPP_NUMBER}&text=${encodedText}` : `https://web.whatsapp.com/send?phone=${WHATSAPP_NUMBER}&text=${encodedText}`;
    window.open(url, '_blank');
  }

function registrarCotizacion(folio, total) {
  // SUSTITUYE LO SIGUIENTE CON LA URL QUE COPIASTE EN EL PASO ANTERIOR
  const WEBHOOK_URL = "https://script.google.com/macros/s/AKfycbxfDCBJHoKb29traKX5mx2rkBK_ruh7bbCZxx5opQR47EQ688W7icxKaUi4U7xwLGM4GA/exec"; 
  
  const resumenProductos = cart.map(i => `${i.qty}x ${i.name}`).join(' | ');

  fetch(WEBHOOK_URL, {
    method: 'POST',
    mode: 'no-cors', 
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      folio: folio,
      productos: resumenProductos,
      total: total
    })
  });
}

function generateCyloPDF() {
  if (!cart || cart.length === 0) {
    alert('El carrito está vacío.');
    return;
  }

  const today = new Date().toLocaleDateString('es-GT');
  const quoteNumber = 'CYLO-' + Math.floor(Math.random() * 1000000);
  
  // CÁLCULO ÚNICO
  let grandTotal = 0;
  const rows = cart.map((item) => {
    const subtotal = item.qty * (item.price || 0);
    grandTotal += subtotal;
    return `
      <tr style="border-bottom: 1px solid #eee;">
        <td style="padding: 10px; text-align: center;">${item.qty}</td>
        <td style="padding: 10px; font-size: 11px;">${item.name}</td>
        <td style="padding: 10px; text-align: right;">${formatMoney(item.price || 0)}</td>
        <td style="padding: 10px; text-align: right; font-weight: bold;">${formatMoney(subtotal)}</td>
      </tr>`;
  }).join('');

  const totalFormateado = formatMoney(grandTotal);

  // DISPARO DEL REGISTRO (El mensajero actúa aquí)
  registrarCotizacion(quoteNumber, totalFormateado);

  const printContent = `
    <html>
    <head>
      <title>Cotización ${quoteNumber}</title>
      <style>
        body { font-family: Arial, sans-serif; color: #333; margin: 0; padding: 0; }
        .page { padding: 40px; max-width: 800px; margin: auto; }
        @media print {
          @page { size: letter portrait; margin: 1cm; }
