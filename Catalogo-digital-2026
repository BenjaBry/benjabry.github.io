<style>

/* === 1. RESET RESPONSIVO CORREGIDO (MANTIENE EL STICKY) === */
  * {
    box-sizing: border-box !important;
    max-width: 100%; /* Previene que elementos sueltos rompan el ancho */
  }
  
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    /* ⚠️ Se eliminó overflow-x: hidden de aquí para no "matar" el buscador */
  }

  /* Le aplicamos el candado de desbordamiento SOLO al catálogo */
  #catalog-container {
    overflow-x: hidden !important; 
    width: 100% !important;
  }

  /* === 2. AJUSTE DE BUSCADOR Y MÁRGENES PARA CELULARES === */
  @media (max-width: 768px) {
    .search-bar {
      padding: 10px 15px !important;
      z-index: 9999 !important; /* Asegura que flote sobre todo */
    }
    
    .cart-box {
      width: 90% !important;
      padding: 15px !important;
    }
  }

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#1B2A4A;--navy2:#0D1A30;--orange:#F47B20;--light:#F4F6F9;--mid:#E2E6EC;--text:#1A2535;--muted:#8A95A3}
body{font-family:'Inter',sans-serif;background:var(--light);color:var(--text)}

/* COVER */
.cover{min-height:100vh;display:grid;grid-template-columns:42% 1fr;background:var(--navy2)}
.cv-left{background:var(--orange);display:flex;flex-direction:column;justify-content:center;padding:64px 48px;clip-path:polygon(0 0,100% 0,88% 100%,0 100%)}
.cv-logo{font-family:'Montserrat',sans-serif;font-size:clamp(5rem,10vw,8rem);font-weight:900;color:white;line-height:.9;letter-spacing:-4px}
.cv-tagline{font-family:'Montserrat',sans-serif;font-size:.8rem;font-weight:700;color:rgba(255,255,255,.75);letter-spacing:6px;text-transform:uppercase;margin-top:16px}
.cv-divider{width:48px;height:3px;background:rgba(255,255,255,.4);margin:20px 0}
.cv-stats{display:flex;gap:16px;flex-wrap:wrap}
.cv-stat{background:rgba(0,0,0,.15);padding:14px 18px;border-radius:6px;text-align:center}
.cv-stat strong{display:block;font-family:'Montserrat',sans-serif;font-size:1.8rem;font-weight:900;color:white}
.cv-stat span{font-size:.6rem;color:rgba(255,255,255,.65);letter-spacing:2px;text-transform:uppercase}
.cv-right{display:flex;flex-direction:column;justify-content:center;padding:64px 48px 64px 64px}
.cv-title{font-family:'Montserrat',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:900;color:white;line-height:1.15;margin-bottom:32px}
.cv-title em{color:var(--orange);font-style:normal}
.cover-cats{display:flex;flex-direction:column;gap:8px}
.cover-cat{display:flex;align-items:center;gap:10px;padding:9px 14px;background:rgba(255,255,255,.05);border-radius:4px;border-left:3px solid}
.cover-cat-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.cover-cat span:first-of-type{font-size:.78rem;font-weight:600;color:rgba(255,255,255,.8);flex:1;letter-spacing:.3px}
.cover-cat-num{font-size:.65rem;color:rgba(255,255,255,.35);font-family:'Montserrat',sans-serif;font-weight:700}

/* LAYOUT */
.app{display:flex}
.sidebar{width:255px;min-width:255px;background:var(--navy2);position:sticky;top:0;height:100vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.1) transparent}
.sidebar::-webkit-scrollbar{width:3px}
.sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12)}
.sb-top{background:var(--navy);padding:18px 18px 16px;border-bottom:1px solid rgba(255,255,255,.06)}
.sb-logo{font-family:'Montserrat',sans-serif;font-size:1.7rem;font-weight:900;color:white;letter-spacing:-1px}
.sb-logo em{color:var(--orange);font-style:normal}
.sb-year{font-size:.58rem;color:rgba(255,255,255,.35);letter-spacing:3px;text-transform:uppercase;margin-top:3px}
.toc-lbl{font-size:.55rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.25);padding:14px 18px 5px}
.toc-item{display:flex;align-items:center;gap:9px;padding:8px 18px;color:rgba(255,255,255,.7);text-decoration:none;font-size:.75rem;font-weight:500;border-left:3px solid transparent;transition:.12s}
.toc-item:hover{background:rgba(255,255,255,.06);color:white;border-left-color:var(--orange)}
.toc-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.toc-name{flex:1}
.toc-num{background:rgba(255,255,255,.08);color:rgba(255,255,255,.5);font-size:.6rem;font-weight:700;padding:2px 6px;border-radius:20px}

/* MAIN */
.main{flex:1}
.search-bar{background:white;border-bottom:2px solid var(--mid);padding:12px 36px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.06);display:flex;align-items:center;gap:12px}
.search-input{flex:1;border:2px solid var(--mid);border-radius:6px;padding:9px 16px 9px 36px;font-family:'Inter',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;background:var(--light)}
.search-input:focus{border-color:var(--orange);background:white}
.search-wrap{position:relative;flex:1}
.search-ico{position:absolute;left:11px;top:50%;transform:translateY(-50%);font-size:.9rem;pointer-events:none}
.sc{font-size:.75rem;color:var(--muted);white-space:nowrap;font-weight:600}

/* SECTION */
.cat-section{margin-bottom:3px}
.cat-header{padding:26px 36px;background:var(--navy);position:relative;overflow:hidden}
.cat-header::before{content:'';position:absolute;inset:0;background:linear-gradient(100deg,var(--cc) 0%,transparent 50%);opacity:.3}
.cat-header::after{content:'';position:absolute;right:0;top:0;bottom:0;width:5px;background:var(--cc)}
.cat-hc{position:relative;z-index:1;display:flex;align-items:center;gap:16px}
.cat-icon-circ{width:50px;height:50px;border-radius:50%;background:var(--cc);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cat-icon-circ svg{width:24px;height:24px}
.cat-title{font-family:'Montserrat',sans-serif;font-size:1.5rem;font-weight:800;color:white}
.cat-sub{font-size:.7rem;color:rgba(255,255,255,.5);margin-top:2px;letter-spacing:.5px}

/* GRID */
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:2px;background:var(--mid);padding:2px}
.product-card{background:white;display:flex;flex-direction:column;transition:transform .15s,box-shadow .15s}
.product-card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.1);position:relative;z-index:2}
.img-wrap{aspect-ratio:1;overflow:hidden;background:var(--light);display:flex;align-items:center;justify-content:center}
.img-wrap img{width:100%;height:100%;object-fit:contain;padding:8px;transition:transform .25s}
.product-card:hover .img-wrap img{transform:scale(1.06)}
.no-img{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--light);font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:900;color:var(--mid)}
.card-body{padding:11px 13px 13px;display:flex;flex-direction:column;gap:4px;flex:1;border-top:3px solid var(--cc)}
.prod-code{font-size:.58rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--cc)}
.prod-name{font-size:.76rem;font-weight:600;line-height:1.35;flex:1;color:var(--text)}
.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:8px;gap:6px}
.prod-units{font-size:.6rem;color:var(--muted)}
.prod-price{background:var(--cc);color:white;font-family:'Montserrat',sans-serif;font-size:.8rem;font-weight:700;padding:3px 10px;border-radius:4px;white-space:nowrap}

/* FOOTER */
.footer{background:var(--navy2);padding:56px 36px;color:white;text-align:center}
.footer-title{font-family:'Montserrat',sans-serif;font-size:1.8rem;font-weight:900;margin-bottom:6px}
.footer-title em{color:var(--orange);font-style:normal}
.footer-sub{color:rgba(255,255,255,.45);font-size:.85rem;margin-bottom:36px}
.footer-grid{display:flex;justify-content:center;gap:48px;flex-wrap:wrap}
.fi-label{font-size:.58rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:5px}
.fi-val{font-family:'Montserrat',sans-serif;font-size:.95rem;font-weight:700}
.fi-val a{color:var(--orange);text-decoration:none}

@media(max-width:860px){
  .cover{grid-template-columns:1fr}.cv-right,.sidebar{display:none}
  .cv-left{clip-path:none;padding:48px 28px}
  .search-bar{padding:10px 16px}
  .cat-header{padding:18px 18px}
  .products-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr))}
}
@media print{.sidebar,.search-bar{display:none}.products-grid{grid-template-columns:repeat(4,1fr)}}
